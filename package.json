{
  "name": "@zentring/zinvoice",
  "version": "0.1.4",
  "description": "Taiwan e-invoice integration SDK for value-added centers (加值中心電子發票整合套件)",
  "keywords": [
    "taiwan",
    "roc",
    "中華民國",
    "invoice",
    "e-invoice",
    "einvoice",
    "電子發票",
    "發票",
    "加值中心",
    "amego",
    "光貿"
  ],
  "author": "Zentring LTD. <contact@zentring.net>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentring/zinvoice-js.git"
  },
  "homepage": "https://github.com/zentring/zinvoice-js#readme",
  "bugs": {
    "url": "https://github.com/zentring/zinvoice-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
